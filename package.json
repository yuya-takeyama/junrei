{
  "name": "junrei",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@11.10.0",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "start": "node scripts/start.mjs",
    "capture": "pnpm --filter @junrei/capture-proxy start",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "turbo run test && node --test scripts/junrei-launcher.test.mjs && ruby scripts/validate-skills.rb"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "turbo": "2.10.5",
    "typescript": "^6.0.3"
  }
}
